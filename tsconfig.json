{
    "extends": "./tsconfig.strict.json",
    "compilerOptions": {
        "target": "ESNext",
        "lib": [
            "ESNext"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": [
            "node"
        ],
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "isolatedModules": true,
        "isolatedDeclarations": true
    },
    "include": [
        "tsdown.config.mts",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
