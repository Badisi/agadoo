{
    "name": "@badisi/agadoo",
    "version": "4.0.1",
    "description": "Check whether a package is tree-shakeable.",
    "homepage": "https://github.com/Badisi/agadoo",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "sideEffects": false,
    "type": "module",
    "main": "./index.mjs",
    "module": "./index.mjs",
    "exports": {
        ".": {
            "types": "./index.d.mts",
            "default": "./index.mjs"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "bagadoo": "bin/bagadoo"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Badisi/agadoo.git"
    },
    "keywords": [
        "agadoo",
        "rollup",
        "analyzer",
        "checker",
        "tree-shaking",
        "tree-shakeable",
        "esm"
    ],
    "scripts": {
        "check-updates": "npx @badisi/check-updates -i",
        "typecheck": "tsc --noEmit",
        "start": "tsx src/cli.ts",
        "test": "vitest",
        "test:ci": "vitest run",
        "build": "tsc --noEmit && tsdown",
        "release": "npm publish ./dist --access public"
    },
    "engines": {
        "node": ">= 20.12.0"
    },
    "dependencies": {
        "@rollup/plugin-virtual": "^3.0.2",
        "rollup": "^4.62.2"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "tsdown": "^0.22.13",
        "tsx": "^4.23.1",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "allowScripts": {
        "esbuild": true,
        "fsevents": true
    }
}
